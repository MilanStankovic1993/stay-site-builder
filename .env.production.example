APP_NAME="StaySite Builder"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.com
APP_TIMEZONE=Europe/Belgrade
APP_LOCALE=sr
APP_FALLBACK_LOCALE=en

APP_MAINTENANCE_DRIVER=file
PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=staysite_builder
DB_USERNAME=staysite_user
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=staysite_builder

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"

PADDLE_SANDBOX=false
PADDLE_CLIENT_SIDE_TOKEN=
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
CASHIER_CURRENCY=EUR
CASHIER_CURRENCY_LOCALE=sr

SITE_BILLING_RECOMMENDED_PLAN=advanced_yearly
SITE_BILLING_SETUP_FEE_AMOUNT=14900
SITE_BILLING_SETUP_FEE_PRICE_ID=
SITE_BILLING_BASIC_MONTHLY_AMOUNT=4900
SITE_BILLING_BASIC_YEARLY_AMOUNT=49000
SITE_BILLING_ADVANCED_MONTHLY_AMOUNT=12900
SITE_BILLING_ADVANCED_YEARLY_AMOUNT=129000
SITE_BILLING_PRO_MONTHLY_AMOUNT=34900
SITE_BILLING_PRO_YEARLY_AMOUNT=349000
SITE_BILLING_BASIC_MONTHLY_PRICE_ID=
SITE_BILLING_BASIC_YEARLY_PRICE_ID=
SITE_BILLING_ADVANCED_MONTHLY_PRICE_ID=
SITE_BILLING_ADVANCED_YEARLY_PRICE_ID=
SITE_BILLING_PRO_MONTHLY_PRICE_ID=
SITE_BILLING_PRO_YEARLY_PRICE_ID=

VITE_APP_NAME="${APP_NAME}"
